# =============================================================================
#  .env.example  —  TEMPLATE of every secret/setting the project uses.
#  HOW TO USE: copy the blocks you need into the right .env file, then fill in
#  real values. The REAL .env files are git-ignored (never committed); only this
#  example is committed, as documentation.
#
#  This project uses SEVERAL .env files (each script loads the one NEXT TO it):
#    - ROOT .env            -> read by docker-compose (the block right below)
#    - data-geneator/.env   -> the generator
#    - kafka-debezium/.env  -> the connector script
#    - consumer/.env        -> the Kafka->MinIO consumer
#    - docker/dags/.env     -> the Airflow DAGs (MinIO + Snowflake)
# =============================================================================

# ----- ROOT .env  (used by docker-compose.yml via ${VAR}) --------------------
# Banking Postgres (the source database container)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=banking
# MinIO (the data-lake container)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
# Airflow's OWN metadata database (separate from the banking DB)
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=changeme
AIRFLOW_DB_NAME=airflow

# ----- data-geneator/.env  (the generator connects to Postgres from your Mac) -
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=banking
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=changeme

# ----- kafka-debezium/.env  (the connector's DB host = docker SERVICE NAME) ---
# POSTGRES_HOST=postgres        # NOT localhost — Debezium runs inside docker
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=changeme
# POSTGRES_DB=banking

# ----- consumer/.env  (Kafka + MinIO, used by the consumer on your Mac) -------
# KAFKA_BOOTSTRAP=host.docker.internal:29092   # how the Mac reaches Kafka
# KAFKA_GROUP=minio-landing-group
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=changeme
# MINIO_BUCKET=raw

# ----- docker/dags/.env  (MinIO + Snowflake, used by the Airflow DAGs) --------
# MINIO_ENDPOINT=http://minio:9000     # service name (the DAG runs inside docker)
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=changeme
# MINIO_BUCKET=raw
# SNOWFLAKE_ACCOUNT=YOURORG-YOURACCT
# SNOWFLAKE_USER=svc_airflow_user
# SNOWFLAKE_ROLE=SVC_AIRFLOW_ROLE
# SNOWFLAKE_WAREHOUSE=COMPUTE_WH
# SNOWFLAKE_DB=banking
# SNOWFLAKE_SCHEMA=raw
# SNOWFLAKE_PRIVATE_KEY=<your RSA private key body>   # key-pair (JWT) auth
